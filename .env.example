PORT= #Puerto en el que la aplicación web escuchará las solicitudes HTTP. Ejemplo= 3000, 4200, 5000. (Por defecto= 3000)
DB_HOST= #Host o dirección IP del servidor de base de datos. Puede ser "localhost" para desarrollo o un nombre DNS/IP para producción. Ejemplo= localhost, db.example.com
DB_PORT= #Puerto del servicio de base de datos. Ejemplo= 5432 para PostgreSQL, 1433 para SQL Server. (Por defecto según el motor)
DB_NAME= #Nombre de la base de datos a la que se conectará la aplicación. Ejemplo= myapp_db
DB_USER= #Usuario con permisos para conectarse a la base de datos. Evitar usar el superusuario en producción; crear un rol con permisos mínimos necesarios.
DB_PASSWORD= #Contraseña del usuario de la base de datos. Mantenerla secreta; usar secret manager o variables de entorno en CI/CD.
DB_MAX_CONNECT= #Límite máximo de conexiones simultáneas desde la aplicación hacia la base de datos. Establecer según capacidad del servidor y pool de la app. Ejemplo= 10, 20
DB_IDLETIMEOUT= #Tiempo (en segundos o milisegundos según la librería) que una conexión inactiva permanece en el pool antes de cerrarse. Ejemplo= 300 (segundos)
DB_CONNECTIONTIMEOUT= #Tiempo máximo de espera (en milisegundos) para establecer una conexión antes de que falle la operación. Ejemplo= 5000 (ms)